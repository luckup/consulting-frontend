# Contact form — Formspree (https://formspree.io)
# 1. Create a form at formspree.io and set notifications to yuji@moonsofts.net
# 2. Copy the form ID from https://formspree.io/f/{form_id}
# 3. Add moonsofts.com and localhost under Formspree → form Settings → allowed domains
VITE_FORMSPREE_FORM_ID=

# Recommended for production (canonical URLs, Open Graph, JSON-LD). No trailing slash.
# VITE_SITE_URL=https://moonsofts.com

# API base URL (optional). Only if you host a separate backend.
VITE_API_URL=

# --- CDN images (required for production build & recommended for dev) ---
VITE_CDN_BASE_URL=https://kmbR6bCYbcA9kB47.public.blob.vercel-storage.com

# Required only for npm run vercel:blob:upload (from Vercel → Storage → Blob → token)
# BLOB_READ_WRITE_TOKEN=

# Optional: use bundled local assets in dev only (requires files in src/assets/)
# VITE_USE_LOCAL_ASSETS=true
